# MQTT topic identifiers
# Generated automatically on first API run and saved in .env.
# Copy the share code printed at API startup into each tray client's Settings.
# PROJECT_ID=
# SYSTEM_ID=

# Optional source database
# Leave DB_PATH blank until a real source database is connected.
DB_PATH=
DB_TABLE=StatusRecords
DB_DATE_COLUMN=RecordDate

# Generic source paths
# BASE_PATH is an optional shared root for all folders below.
BASE_PATH=C:/path/to/source
RAW_DATA_PATH=raw
ARCHIVED_DATA_PATH=archive
REPORT_WORK_PATH=reports/work
REPORT_SUMMARY_PATH=reports/summary
REPORT_FINAL_PATH=reports/final
SOURCE_LOG_PATH=logs

# File extensions scanned by the generic skeleton checker
RAW_DATA_EXTENSIONS=.csv,.log,.txt
REPORT_EXTENSIONS=.xlsx,.xls,.txt,.pdf

# Status thresholds
# Hours since last source record before the monitor is considered stale.
GREEN_THRESHOLD_HOURS=26

# MQTT broker
MQTT_BROKER_HOST=localhost
# Plain MQTT port used by this server to publish.
MQTT_BROKER_PORT=1883
# WebSocket port clients use to subscribe.
MQTT_WS_PORT=9001
# Leave blank if the broker has no authentication.
MQTT_USERNAME=
MQTT_PASSWORD=

# Check schedule
# How often the checker runs (cron syntax, default every 10 minutes).
CHECK_CRON=*/10 * * * *

# REST API
API_PORT=3847
# Set to a comma-separated list of allowed origins, or * to allow all.
API_CORS_ORIGIN=*
# Optional absolute path for the local history SQLite DB (auto-created).
# Defaults to data/history.db inside the status-monitor-api folder.
# HISTORY_DB_PATH=
